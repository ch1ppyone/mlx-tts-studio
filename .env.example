# MLX TTS Studio — environment variables
# Copy to .env and adjust as needed

# Server
MLX_TTS_HOST=0.0.0.0
MLX_TTS_PORT=7860
MLX_TTS_PORT_RANGE=10

# Audio
MLX_TTS_AUDIO_TTL=7200
MLX_TTS_MAX_AUDIO=200

# Preview
MLX_TTS_PREVIEW_TEXT=Hello! This is a preview of how I sound.

# Browser auto-open (set to 1 to disable)
# MLX_TTS_NO_BROWSER=1

# Install optional Kokoro fallback dependency during install.sh
# MLX_TTS_INSTALL_ESPEAK=1

# Paths (optional)
# MLX_TTS_TEMP_DIR=
# MLX_TTS_REF_DIR=~/.mlx-tts-studio/refs
